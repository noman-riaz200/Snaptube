# SnapTube APK Website - LiteSpeed Optimized Configuration
# Place this file in the web root.

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /Snaptube/

    # === HTTPS ENFORCEMENT (Disabled for local development) ===
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

    # Redirect trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]

    # === REMOVE .PHP EXTENSION ===
    # Redirect external .php requests to extensionless URL
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
    RewriteRule ^ %1 [R=301,L]

    # Rewrite extensionless URLs to actual .php files internally
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # Sitemap.xml to sitemap.php rewrite
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Pretty URLs for dynamic pages (page/slug -> page.php?slug=slug)
    RewriteRule ^page/([^/]+)$ page.php?slug=$1 [L,QSA]

    # Protect sensitive files
    RewriteRule ^(config\.php|database\.sql) - [F,L]

    # Simple 404 fallback to index for SPA-like behavior (optional)
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule . /index.php [L]
</IfModule>

# Gzip / Brotli compression for LiteSpeed
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/rss+xml application/xml
</IfModule>

<IfModule LiteSpeed>
    SetEnv no-gzip 0
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>

