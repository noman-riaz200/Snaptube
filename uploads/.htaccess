# Deny execution of PHP files in uploads directory
<FilesMatch "\.(php|php\.|php3|php4|php5|phtml|pl|py|jsp|asp|aspx|cgi|sh|bash)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to .htaccess itself
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# Disable PHP engine
php_flag engine off

